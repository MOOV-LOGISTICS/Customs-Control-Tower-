{
  "openapi": "3.0.3",
  "info": {
    "title": "Warehouse Logistics Management System - Complete OpenAPI Documentation",
    "description": "Includes all module APIs for purchase orders, sales orders, inbound, outbound, inventory, products, warehouse third-party imports, logistics shipping booking EDI, etc.",
    "version": "1.0.0",
    "contact": {
      "name": "Warehouse System Technical Team",
      "description": "Complete business interface collection"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Production environment service root path"
    }
  ],
  "tags": [
    {
      "name": "purchaseOrders",
      "description": "Purchase Order related interfaces"
    },
    {
      "name": "salesOrders",
      "description": "Sales Order related interfaces"
    },
    {
      "name": "inbound",
      "description": "Inbound related interfaces (including ASN)"
    },
    {
      "name": "outbound",
      "description": "Outbound related interfaces (including WMS sync)"
    },
    {
      "name": "inventory",
      "description": "Inventory related interfaces"
    },
    {
      "name": "warehouseThird",
      "description": "Warehouse third-party data import interfaces"
    },
    {
      "name": "product",
      "description": "Product related interfaces"
    },
    {
      "name": "logisticsShipment",
      "description": "Logistics shipping/booking/EDI receipt related interfaces"
    }
  ],
  "components": {
    "parameters": {
      "page": {
        "name": "page",
        "in": "query",
        "description": "Pagination page number, default 1",
        "required": false,
        "schema": {
          "type": "integer",
          "format": "int32",
          "default": 1
        }
      },
      "size": {
        "name": "size",
        "in": "query",
        "description": "Number of items per page, default 10",
        "required": false,
        "schema": {
          "type": "integer",
          "format": "int32",
          "default": 10
        }
      }
    },
    "responses": {
      "SuccessResponse": {
        "description": "General success response",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "description": "Response code 200=success",
                  "example": 200
                },
                "msg": {
                  "type": "string",
                  "description": "Response description",
                  "example": "Operation successful"
                },
                "data": {
                  "type": "object",
                  "description": "Response data body"
                }
              },
              "required": ["code", "msg"]
            }
          }
        }
      },
      "FileResponse": {
        "description": "File download/export general response (Excel)",
        "content": {
          "application/vnd.ms-excel": {
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        }
      },
      "FileUploadForm": {
        "description": "Excel file upload general form format",
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "properties": {
                "file": {
                  "type": "string",
                  "format": "binary",
                  "description": "Excel file to import"
                }
              },
              "required": ["file"]
            }
          }
        }
      }
    }
  },
  "paths": {
    "/admin-api/openApi/purchaseOrders/delete": {
      "post": {
        "tags": ["purchaseOrders"],
        "summary": "Delete purchase order",
        "description": "Delete specified purchase order by order number",
        "requestBody": {
          "description": "Purchase order deletion parameters",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "orderNo": {
                    "type": "string",
                    "description": "Purchase order number",
                    "example": "PO20260113001"
                  }
                },
                "required": ["orderNo"]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessResponse"
          }
        }
      }
    },
