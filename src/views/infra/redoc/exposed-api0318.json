{
  "openapi": "3.0.3",
  "info": {
    "title": "仓储物流管理系统-全量OpenAPI接口文档",
    "description": "包含采购订单、销售订单、入库、出库、库存、产品、仓储第三方导入、物流装运订舱EDI等全模块API",
    "version": "1.0.0",
    "contact": {
      "name": "仓储系统技术组",
      "description": "全量业务接口合集"
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "生产环境服务根路径"
    }
  ],
  "tags": [
    {
      "name": "purchaseOrders",
      "description": "采购订单相关接口"
    },
    {
      "name": "salesOrders",
      "description": "销售订单相关接口"
    },
    {
      "name": "inbound",
      "description": "入库相关接口(含ASN单)"
    },
    {
      "name": "outbound",
      "description": "出库相关接口(含WMS同步)"
    },
    {
      "name": "inventory",
      "description": "库存相关接口"
    },
    {
      "name": "warehouseThird",
      "description": "仓储第三方数据导入接口"
    },
    {
      "name": "product",
      "description": "产品相关接口"
    },
    {
      "name": "logisticsShipment",
      "description": "物流装运/订舱/EDI回执相关接口"
    }
  ],
  "components": {
    "parameters": {
      "page": {
        "name": "page",
        "in": "query",
        "description": "分页页码，默认1",
        "required": false,
        "schema": {
          "type": "integer",
          "format": "int32",
          "default": 1
        }
      },
      "size": {
        "name": "size",
        "in": "query",
        "description": "每页显示条数，默认10",
        "required": false,
        "schema": {
          "type": "integer",
          "format": "int32",
          "default": 10
        }
      }
    },
    "responses": {
      "SuccessResponse": {
        "description": "请求成功通用响应",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "integer",
                  "description": "响应码 200=成功",
                  "example": 200
                },
                "msg": {
                  "type": "string",
                  "description": "响应描述",
                  "example": "操作成功"
                },
                "data": {
                  "type": "object",
                  "description": "响应数据体"
                }
              },
              "required": ["code", "msg"]
            }
          }
        }
      },
      "FileResponse": {
        "description": "文件下载/导出通用响应(Excel)",
        "content": {
          "application/vnd.ms-excel": {
            "schema": {
              "type": "string",
              "format": "binary"
            }
          }
        }
      },
      "FileUploadForm": {
        "description": "Excel文件上传通用表单格式",
        "content": {
          "multipart/form-data": {
            "schema": {
              "type": "object",
              "properties": {
                "file": {
                  "type": "string",
                  "format": "binary",
                  "description": "待导入的Excel文件"
                }
              },
              "required": ["file"]
            }
          }
        }
      }
    }
  },
  "paths": {
    "/admin-api/openApi/purchaseOrders/delete": {
      "post": {
        "tags": ["purchaseOrders"],
        "summary": "删除采购订单",
        "description": "根据订单号删除指定采购订单",
        "requestBody": {
          "description": "采购订单删除参数",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "orderNo": {
                    "type": "string",
                    "description": "采购订单号",
                    "example": "PO20260113001"
                  }
                },
                "required": ["orderNo"]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessResponse"
          }
        }
      }
    },
